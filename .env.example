# =============================================================================
# Variáveis de ambiente — ecommerce-premium
# Copie este arquivo para .env.local e preencha com seus valores reais
# NUNCA comite .env.local no Git
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase (obrigatório para todas as fases)
# Encontre em: https://supabase.com/dashboard/project/<id>/settings/api
# ---------------------------------------------------------------------------

# URL do projeto Supabase (pública — pode ir ao frontend)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co

# Chave anon/pública (pode ir ao frontend — limitada por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Chave de service role (SEGREDO — apenas no servidor, nunca no frontend)
# Bypassa RLS — usar somente em Route Handlers / Server Actions protegidos
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ---------------------------------------------------------------------------
# PicPay (Fase 2 — não preencher agora)
# Token da loja em: https://ecommerce.picpay.com (Vendas Online > Credenciais)
# ---------------------------------------------------------------------------

# Token da loja (SEGREDO — apenas no servidor)
PICPAY_TOKEN=

# URL base da aplicação (para webhooks e redirects do PicPay)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# API de Frete (Fase 3 — não preencher agora)
# Melhor Envio: https://melhorenvio.com.br/developers
# ---------------------------------------------------------------------------

MELHOR_ENVIO_TOKEN=
MELHOR_ENVIO_CEP_ORIGIN=01310100

# ---------------------------------------------------------------------------
# Ambiente
# ---------------------------------------------------------------------------

NODE_ENV=development
